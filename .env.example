# Copy this file to .env and replace values for your local environment.
# Never commit the real .env file to source control.

APP_ENV=development
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
COLLECTION_NAME=enterprise_documents
UPLOAD_DIR=data/documents
VECTOR_DB_PATH=db

# Optional security or UI-related values can be added here later.
# API_SECRET_KEY=replace-with-a-secure-secret
# ALLOWED_ORIGINS=http://localhost:5173
